# Copy this to .env for local dev, set these as Railway environment variables in production

SECRET_KEY=your-secret-key-here
DEBUG=False
ALLOWED_HOSTS=yourdomain.up.railway.app,localhost,127.0.0.1

# Admin access - only this email gets admin dashboard access
ADMIN_EMAIL=your-admin-email@example.com

# Optional: Railway provides DATABASE_URL automatically if you add a Postgres plugin
# For Neon PostgreSQL use your connection string:
# DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require
